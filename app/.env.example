# ============================================================
# SMA — Required Environment Variables
# Copy this file to .env.local and fill in real values.
# ============================================================

# Railway / Hosting (required on Railway — do NOT set locally)
HOSTNAME=0.0.0.0                # Bind to all interfaces (Next.js 16 standalone on Railway)
AUTH_TRUST_HOST=true            # Trust Railway's reverse-proxy X-Forwarded-Host header

# Authentication (NextAuth v5)
AUTH_SECRET=                    # NextAuth secret (generate with: openssl rand -hex 32)
NEXTAUTH_URL=                   # App URL (e.g., https://sma.up.railway.app)

# Database
DATABASE_URL=                   # PostgreSQL connection string (e.g., postgresql://user:pass@host:5432/db)

# Redis (Rate Limiting — optional, gracefully degrades if absent)
UPSTASH_REDIS_REST_URL=         # Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=       # Upstash Redis REST auth token

# AI (Lesson Plan Generation)
ANTHROPIC_API_KEY=              # Claude API key for lesson plan generation
